POSTGRES_DB=tabularag
POSTGRES_USER=tabularag
POSTGRES_PASSWORD=tabularag_dev_password

DATABASE_URL=postgresql://tabularag:tabularag_dev_password@postgres:5432/tabularag
QDRANT_URL=http://qdrant:6333
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_THREADS=4
EMBEDDING_BATCH_SIZE=768
INDEX_EMBED_BATCH_SIZE=768
QDRANT_UPSERT_BATCH_SIZE=1000
QDRANT_UPSERT_PARALLEL=2
QDRANT_UPSERT_WAIT=false
QDRANT_BULK_INGEST_MODE=true
QDRANT_BULK_HNSW_M=0
QDRANT_BULK_INDEXING_THRESHOLD=0
QDRANT_FINAL_HNSW_M=16
QDRANT_FINAL_INDEXING_THRESHOLD=20000
INDEX_WORKER_CONCURRENCY=4
